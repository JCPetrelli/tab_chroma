    },
    "working": {
      "r": 189, "g": 147, "b": 249,
      "label": "Claude is working"
    },
    "done": {
      "r": 80, "g": 250, "b": 123,
      "label": "Ready for input"
    },
    "attention": {
      "r": 255, "g": 184, "b": 108,
      "label": "Needs attention"
    },
    "permission": {
      "r": 255, "g": 85, "b": 85,
      "label": "Needs approval"
    }
  }
}
